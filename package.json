{
  "name": "wos",
  "productName": "WOS",
  "version": "0.1.0",
  "description": "WOS — AI Agent Desktop App",
  "main": ".vite/build/main.js",
  "scripts": {
    "start": "env -u ELECTRON_RUN_AS_NODE electron-forge start -- --no-deprecation",
    "predev": "electron-rebuild -f -w better-sqlite3",
    "dev": "env -u ELECTRON_RUN_AS_NODE electron-forge start -- --no-deprecation",
    "package": "env -u ELECTRON_RUN_AS_NODE electron-forge package",
    "make": "env -u ELECTRON_RUN_AS_NODE electron-forge make",
    "lint": "tsc --noEmit",
    "pretest": "npm rebuild better-sqlite3",
    "test": "vitest run",
    "rebuild:electron": "electron-rebuild -f -w better-sqlite3",
    "e2e:build": "env -u ELECTRON_RUN_AS_NODE electron-forge package",
    "pree2e:smoke": "electron-rebuild -f -w better-sqlite3",
    "e2e:smoke": "playwright test -c e2e/playwright.config.ts e2e/smoke.spec.ts",
    "pree2e:live": "electron-rebuild -f -w better-sqlite3",
    "e2e:live": "playwright test -c e2e/playwright.config.ts e2e/live.spec.ts --headed --debug",
    "pree2e:trace": "electron-rebuild -f -w better-sqlite3",
    "e2e:trace": "playwright test -c e2e/playwright.config.ts --trace on",
    "postinstall": "patch-package && electron-rebuild -f -w better-sqlite3",
    "pree2e:full": "electron-rebuild -f -w better-sqlite3",
    "e2e:full": "playwright test -c e2e/playwright.config.ts e2e/boot-chat.spec.ts e2e/apps-context.spec.ts e2e/automations.spec.ts e2e/subagents.spec.ts e2e/automation-author-repro.spec.ts"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-dmg": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-vite": "^7.11.1",
    "@electron-forge/shared-types": "^7.11.1",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.1.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/turndown": "^5.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^41.3.0",
    "patch-package": "^8.0.1",
    "playwright": "^1.59.1",
    "tailwindcss": "^4.1.0",
    "tw-animate-css": "^1.3.0",
    "typescript": "^5.8.0",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.91.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@radix-ui/react-collapsible": "^1.1.0",
    "@radix-ui/react-dialog": "^1.1.0",
    "@radix-ui/react-dropdown-menu": "^2.1.0",
    "@radix-ui/react-popover": "^1.1.0",
    "@radix-ui/react-scroll-area": "^1.2.0",
    "@radix-ui/react-select": "^2.1.0",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-slider": "^1.2.0",
    "@radix-ui/react-switch": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.0",
    "@radix-ui/react-tooltip": "^1.1.0",
    "@types/node-cron": "^3.0.11",
    "better-sqlite3": "^12.9.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "drizzle-orm": "^0.45.0",
    "electron-updater": "^6.8.3",
    "glob": "^11.0.0",
    "gray-matter": "^4.0.3",
    "lucide-react": "^0.487.0",
    "mammoth": "^1.12.0",
    "motion": "^12.0.0",
    "node-cron": "^4.2.1",
    "openai": "^6.35.0",
    "pdf-parse": "^2.4.5",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-markdown": "^9.0.0",
    "rehype-highlight": "^7.0.0",
    "remark-gfm": "^4.0.0",
    "sonner": "^2.0.0",
    "tailwind-merge": "^3.0.0",
    "turndown": "^7.2.0",
    "zustand": "^5.0.0"
  },
  "overrides": {
    "tar": "^7.5.1",
    "tmp": "^0.2.5",
    "cacache": "^19.0.1",
    "@tootallnate/once": "^3.0.1"
  }
}
