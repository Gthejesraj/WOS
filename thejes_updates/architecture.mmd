    classDef router   fill:#065f46,stroke:#10b981,color:#fff
    classDef coding   fill:#1d4ed8,stroke:#60a5fa,color:#fff
    classDef meeting  fill:#065f46,stroke:#34d399,color:#fff
    classDef main     fill:#4c1d95,stroke:#a78bfa,color:#fff
    classDef hf       fill:#92400e,stroke:#f59e0b,color:#fff
    classDef training fill:#7f1d1d,stroke:#ef4444,color:#fff
    classDef dataset  fill:#1f2937,stroke:#6b7280,color:#fff
    classDef eval     fill:#164e63,stroke:#06b6d4,color:#fff

    class USER user
    class MEET,CODE,PROJ,AUTO appbox
    class IPC,VLLM,KEYS core
    class JIRA,GCAL,SLACK core
    class ROUTER router
    class C1,C2,C3 coding
    class M1,M2,M3 meeting
    class O1,O2,O3 main
    class HF hf
    class GPU,UPLOAD training
    class DS_CODE,DS_MEET,DS_MAIN dataset
    class EVAL_C,EVAL_M,EVAL_X eval
