# Copy to `.env` in this repo root (gitignored).
# Then: npm install && npm run dev
# `npm run dev` already sets long timeouts + cold-start retries; add keys below for real LLM calls.

# --- Long timeouts for RunPod / Hugging Face Space cold start (milliseconds) ---
# WOS_OPENAI_COMPAT_TIMEOUT_MS=420000
# WOS_ANTHROPIC_HTTP_TIMEOUT_MS=420000

# --- After 502/503, wait then retry same key before rotating (demo-friendly defaults) ---
# WOS_PRIMARY_COLD_RETRY_MS=5000
# WOS_PRIMARY_COLD_RETRY_COUNT=1

# --- Same HF model id, alternate OpenAI /v1 base (optional second hop before Claude/GPT) ---
# WOS_VLLM_GLOBAL_MIRROR_URL=https://your-org-your-space.hf.space/v1
# Per-slot overrides also supported, e.g. WOS_VLLM_CODING_MIRROR_URL=...

# --- Dev/demo only: seed keys into Settings on first DB init (omit in production commits) ---
# WOS_DEV_OPENAI_KEY=
# WOS_DEV_ANTHROPIC_KEY=
# WOS_DEV_HF_KEY=
# WOS_DEV_TOGETHER_KEY=
